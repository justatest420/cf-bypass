{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "browser-rendering",
  "main": "src/index.ts",
  "workers_dev": true,
  "compatibility_flags": ["nodejs_compat_v2"],
  "compatibility_date": "2025-09-17",
  "upload_source_maps": true,
  "browser": {
    "binding": "MYBROWSER"
  }
}
